exports[`tool parameters JSON Schema (wire shape) bash 1`] = `
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "command": {
      "description": "The command to execute",
      "type": "string",
    },
    "description": {
      "description": 
"Clear, concise description of what this command does in 5-10 words. Examples:
Input: ls
Output: Lists files in current directory

Input: git status
Output: Shows working tree status

Input: npm install
Output: Installs package dependencies

Input: mkdir foo
Output: Creates directory 'foo'"
,
      "type": "string",
    },
    "timeout": {
      "description": "Optional timeout in milliseconds",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991,
      "type": "integer",
    },
    "workdir": {
      "description": "The working directory to run the command in. Defaults to the current directory. Use this instead of 'cd' commands.",
      "type": "string",
    },
  },
  "required": [
    "command",
    "description",
  ],
  "type": "object",
}
`;

exports[`tool parameters JSON Schema (wire shape) chimera_audit 1`] = `
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Provide at least one explicit audit seed: files, filePath, symbol, or nodeID. Use chimera_audit_recent for the latest mutation.",
  "properties": {
    "depth": {
      "description": "Impact traversal depth. Defaults to 2, capped at 5.",
      "type": "number",
    },
    "filePath": {
      "description": "Single changed file to audit, absolute or project-relative.",
      "type": "string",
    },
    "files": {
      "description": "Changed files to audit, absolute or project-relative.",
      "items": {
        "type": "string",
      },
      "type": "array",
    },
    "kind": {
      "description": "Optional node kind filter when resolving audit seed symbols.",
      "enum": [
        "file",
        "module",
        "class",
        "struct",
        "interface",
        "trait",
        "protocol",
        "function",
        "method",
        "property",
        "field",
        "variable",
        "constant",
        "enum",
        "enum_member",
        "type_alias",
        "namespace",
        "parameter",
        "import",
        "export",
        "route",
        "component",
      ],
      "type": "string",
    },
    "limit": {
      "description": "Maximum propagation findings to return. Defaults to 30, capped at 100.",
      "type": "number",
    },
    "nodeID": {
      "description": "Exact CodeGraph node id to use as an audit seed.",
      "type": "string",
    },
    "range": {
      "description": "Optional changed source range inside filePath.",
      "properties": {
        "endColumn": {
          "description": "Optional 1-based end column within endLine.",
          "type": "number",
        },
        "endLine": {
          "description": "Optional 1-based end line for the source range. Defaults to the start line when omitted.",
          "type": "number",
        },
        "startColumn": {
          "description": "Optional 1-based start column within startLine.",
          "type": "number",
        },
        "startLine": {
          "description": "1-based start line for the source range.",
          "type": "number",
        },
      },
      "required": [
        "startLine",
      ],
      "type": "object",
    },
    "refresh": {
      "description": "Refresh CodeGraph when stale: the index is empty, watcher has pending files, or git reports dirty source files. Defaults to true.",
      "type": "boolean",
    },
    "symbol": {
      "description": "Changed symbol to audit when file/range is not precise enough.",
      "type": "string",
    },
  },
  "type": "object",
}
`;

